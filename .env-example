# Copy to .env and fill in values as needed. .env is gitignored.

# Output directories — override defaults if you want runs/checkpoints elsewhere.
# RUN_DIR=runs
# CHECKPOINT_DIR=checkpoints

# Optional: Weights & Biases. Leave unset to disable.
# WANDB_API_KEY=
# WANDB_PROJECT=sine-wave-denoising

# Optional: pin a global random seed for reproducibility.
# SEED=42
